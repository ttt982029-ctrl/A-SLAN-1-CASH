<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Aslan Tap Game</title>

<!-- Telegram WebApp Script -->
<script src="https://telegram.org/js/telegram-web-app.js"></script>

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: radial-gradient(circle at top, #0f0f0f, #000);
        color: #FFD700;
        text-align: center;
    }

    h1 {
        margin-top: 20px;
        font-size: 28px;
        letter-spacing: 2px;
    }

    .container {
        padding: 20px;
    }

    .coin {
        width: 180px;
        height: 180px;
        margin: 40px auto;
        border-radius: 50%;
        background: linear-gradient(145deg, #FFD700, #b89600);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        font-weight: bold;
        color: black;
        box-shadow: 0 0 25px #FFD700;
        cursor: pointer;
        transition: transform 0.1s;
    }

    .coin:active {
        transform: scale(0.9);
    }

    .stats {
        margin-top: 20px;
        font-size: 18px;
    }

    .energy-bar {
        width: 80%;
        height: 12px;
        background: #222;
        border-radius: 10px;
        margin: 10px auto;
        overflow: hidden;
    }

    .energy-fill {
        height: 100%;
        width: 100%;
        background: #FFD700;
        transition: width 0.3s;
    }

    button {
        margin-top: 20px;
        padding: 12px 25px;
        border: none;
        border-radius: 8px;
        background: #FFD700;
        color: black;
        font-weight: bold;
        cursor: pointer;
    }

    button:hover {
        background: #ffcc00;
    }

    .section {
        margin-top: 30px;
        padding: 15px;
        border-top: 1px solid #333;
    }
</style>
</head>
<body>

<h1>🦁 ASLAN TAP GAME</h1>

<div class="container">

    <div class="coin" id="tapBtn">TAP</div>

    <div class="stats">
        Coins: <span id="coins">0</span><br>
        Energy: <span id="energy">100</span>/100
    </div>

    <div class="energy-bar">
        <div class="energy-fill" id="energyFill"></div>
    </div>

    <div class="section">
        <h3>💰 Buy Tokens</h3>
        <p>Send payment manually and click confirm</p>
        <button onclick="buyToken()">Buy Token</button>
    </div>

    <div class="section">
        <h3>📢 Community</h3>
        <button onclick="joinTelegram()">Join Telegram</button>
    </div>

</div>

<script>
let coins = 0;
let energy = 100;
const maxEnergy = 100;

const coinsEl = document.getElementById("coins");
const energyEl = document.getElementById("energy");
const energyFill = document.getElementById("energyFill");
const tapBtn = document.getElementById("tapBtn");

// Tap logic
tapBtn.addEventListener("click", () => {
    if (energy > 0) {
        coins++;
        energy--;

        updateUI();

        // Animation effect
        tapBtn.style.boxShadow = "0 0 40px #fff";
        setTimeout(() => {
            tapBtn.style.boxShadow = "0 0 25px #FFD700";
        }, 100);
    }
});

// Energy regeneration
setInterval(() => {
    if (energy < maxEnergy) {
        energy += 1;
        updateUI();
    }
}, 1000);

// Update UI
function updateUI() {
    coinsEl.textContent = coins;
    energyEl.textContent = energy;
    energyFill.style.width = (energy / maxEnergy) * 100 + "%";
}

// Fake Buy Token
function buyToken() {
    alert("Send payment to: YOUR WALLET ADDRESS\nThen contact admin.");
}

// Telegram button
function joinTelegram() {
    window.open("https://t.me/yourchannel", "_blank");
}

// Telegram WebApp init
if (window.Telegram && Telegram.WebApp) {
    Telegram.WebApp.expand();
}
</script>

</body>
</html>